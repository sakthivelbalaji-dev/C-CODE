{
  "name": "c-code-lab-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npm run install:frontend",
    "dev": "npm --prefix frontend run dev",
    "dev:api": "cd backend && uvicorn app.main:app --reload",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview",
    "install:frontend": "npm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
